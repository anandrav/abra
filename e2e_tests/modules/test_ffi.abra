#foreign
fn pass_int(i: int) -> int

#foreign
fn pass_bool(i: bool) -> bool

#foreign
fn pass_void(v: void) -> void

#foreign
fn pass_string(s: string) -> string

#foreign
fn pass_struct(s: MyStruct) -> MyStruct

#foreign
fn pass_enum(e: MyEnum) -> MyEnum

#foreign
fn pass_tuple(e: (bool, int, string)) -> (bool, int, string)

#foreign
fn pass_option(o: option<string>) -> option<string>

#foreign
fn pass_array(a: array<int>) -> array<int>

#foreign
fn pass_nested_array(a: array<array<string>>) -> array<array<string>>

#foreign
fn pass_result_struct(r: result<MyStruct, MyEnum>) -> result<MyStruct, MyEnum>

#foreign
fn pass_array_and_option(programs: array<string>, stdin: option<string>) -> string

#foreign
type MyStruct = {
    i: int
    b: bool
    v: void
    s: string
}

#foreign
type MyEnum =
    | Int(int)
    | Bool(bool)
    | Void
    | AnotherVoid(void)
    | String(string)

