use test_ffi // TODO: make another native module like "test_ffi2" to make sure IDs are assigned to foreign functions properly

println(pass_int(35))
println(pass_bool(false))
println(pass_void(nil))
println(pass_string("mystring"))
let s = pass_struct(MyStruct(23, true, nil, "another"))
println(s.i)
println(s.b)
println(s.v)
println(s.s)
let e = pass_enum(MyEnum.String("yet another"))
match e {
    MyEnum.String(s) -> println(s)
    _ -> println("<wrong variant>")
}
let e = pass_enum(MyEnum.Void)
match e {
    MyEnum.Void -> nil
    _ -> println("<wrong variant>")
}
let e = pass_enum(MyEnum.AnotherVoid(nil))
match e {
    MyEnum.AnotherVoid(nil) -> nil
    _ -> println("<wrong variant>")
}
let t = pass_tuple((true, 2, "3"))
println(t)
let o = pass_option(option.some("some"))
match o {
    option.some(s) -> println(s)
    _ -> println("wrong variant")
}
let a = pass_array([ 1, 2, 3, 4, 5, 6 ])
println(a)
let na = pass_nested_array([ ["a", "b"], ["c"] ])
println(na)
let rok = pass_result_struct(result.ok(MyStruct(42, false, nil, "test")))
match rok {
    result.ok(s) -> println(s.i .. " " .. s.s)
    result.err(_) -> println("wrong")
}
let rerr = pass_result_struct(result.err(MyEnum.Int(99)))
match rerr {
    result.ok(_) -> println("wrong")
    result.err(MyEnum.Int(n)) -> println(n)
    result.err(_) -> println("wrong")
}

// store foreign function in variable/use as lambda
let pb = pass_bool
println(pb(true))

// array + option as consecutive foreign function params
println(pass_array_and_option(["echo"], option.none))
