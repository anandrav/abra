#!/bin/bash
set -euo pipefail

QUICK=false
VIM=false
VSCODE=false
INTELLIJ=false

CARGO_BUILD_PROFILE="--release"
CARGO_INSTALL_PROFILE=""
CARGO_BUILD_SUBDIR="release"
for arg in "$@"; do
  if [[ "$arg" == "--quick" ]]; then
    QUICK=true
    CARGO_BUILD_PROFILE=""
    CARGO_INSTALL_PROFILE="--debug"
    CARGO_BUILD_SUBDIR="debug"
  elif [[ "$arg" == "--vim" ]]; then
    VIM=true
  elif [[ "$arg" == "--vscode" ]]; then
    VSCODE=true
  elif [[ "$arg" == "--intellij" ]]; then
    INTELLIJ=true
  elif [[ "$arg" == "--all" ]]; then
    VIM=true
    VSCODE=true
    INTELLIJ=true
  fi
done

printf "Installing Abra CLI to Cargo bin...\n"
cargo build $CARGO_BUILD_PROFILE
cargo install $CARGO_INSTALL_PROFILE --bin abra --path abra_cli || {
  printf "Failed!\n"
  echo "Failed to install Abra CLI. Please check your Rust installation." >&2
  exit 1
}
printf "Done\n"

printf "Installing Abra LSP to Cargo bin...\n"
cargo install $CARGO_INSTALL_PROFILE --bin abra-lsp --path abra_lsp || {
  printf "Failed!\n"
  echo "Failed to install Abra LSP." >&2
  exit 1
}
printf "Done\n"

printf "Installing Abra standard modules...\n"
CARGO_ROOT="${CARGO_INSTALL_ROOT:-${CARGO_HOME:-$HOME/.cargo}}"
ABRA_SHARE="$CARGO_ROOT/share/abra"
rm -rf "$ABRA_SHARE"
mkdir -p "$ABRA_SHARE"
cp ./Cargo.toml "$ABRA_SHARE/Cargo.toml"
cp -R ./modules "$ABRA_SHARE/"
mkdir -p "$ABRA_SHARE/target/$CARGO_BUILD_SUBDIR"
for manifest in ./modules/*/rust_project/Cargo.toml; do
  package=$(sed -n 's/^name = "\(.*\)"/\1/p' "$manifest" | head -1)
  for lib in \
    "./target/$CARGO_BUILD_SUBDIR/lib$package.dylib" \
    "./target/$CARGO_BUILD_SUBDIR/lib$package.so" \
    "./target/$CARGO_BUILD_SUBDIR/$package.dll"; do
    if [ -f "$lib" ]; then
      cp "$lib" "$ABRA_SHARE/target/$CARGO_BUILD_SUBDIR/"
    fi
  done
done
printf "Done\n"

install_vim_syntax_highlighting() {
VIM_DIR="$HOME/.vim"
if [ -d "$VIM_DIR" ]; then
  printf "Installing Vim syntax highlighting... "
  mkdir -p "$VIM_DIR/syntax"
  mkdir -p "$VIM_DIR/ftdetect"
  cp ./tooling/vim/syntax.vim "$VIM_DIR/syntax/abra.vim"
  cp ./tooling/vim/ftdetect.vim "$VIM_DIR/ftdetect/abra.vim"
  cp ./tooling/vim/scripts.vim "$VIM_DIR/scripts.vim"

  VIMRC="$HOME/.vimrc"
  MYSCRIPTSFILE_LINE='let myscriptsfile = $HOME . "/.vim/scripts.vim"'
  if [ -f "$VIMRC" ] && grep -qF 'myscriptsfile' "$VIMRC"; then
    : # already configured
  else
    echo "$MYSCRIPTSFILE_LINE" >> "$VIMRC"
  fi

  printf "Done\n"
else
  echo "Vim configuration directory not found. Skipping Vim syntax highlighting installation."
fi
}

install_abra_vscode_extension() {
  printf "Installing Abra VS Code extension...\n"

  if ! command -v npm &> /dev/null; then
    echo "'npm' not found. Please install Node.js and npm to proceed." >&2
    return 1
  fi

  if ! command -v vsce &> /dev/null; then
    printf "  - Installing 'vsce' tool... "
    npm install -g @vscode/vsce --quiet || {
      printf "Failed!\n"
      echo "Failed to install 'vsce'. Please check your npm setup." >&2
      return 1
    }
    printf "Done\n"
  fi

  pushd tooling/vscode > /dev/null
  printf "  - Installing npm dependencies... "
  if npm install --quiet > /dev/null 2>&1; then
    printf "Done\n"
  else
    printf "Failed!\n"
    echo "Failed to install npm dependencies." >&2
    popd > /dev/null
    return 1
  fi

  printf "  - Compiling extension... "
  if npm run compile > /dev/null 2>&1; then
    printf "Done\n"
  else
    printf "Failed!\n"
    echo "Failed to compile the VS Code extension." >&2
    popd > /dev/null
    return 1
  fi

  printf "  - Packaging VS Code extension... "
  if vsce package --allow-missing-repository > /dev/null 2>&1; then
    printf "Done\n"
  else
    printf "Failed!\n"
    echo "Failed to package the VS Code extension. Please check the 'vsce' setup." >&2
    popd > /dev/null
    return 1
  fi

  VSIX_FILE=$(ls -t *.vsix 2>/dev/null | head -1)
  if [ -z "$VSIX_FILE" ]; then
    printf "Failed!\n"
    echo "No .vsix file found after packaging." >&2
    popd > /dev/null
    return 1
  fi

  VSCODE_CLIS=()
  command -v code &> /dev/null && VSCODE_CLIS+=(code)
  command -v codium &> /dev/null && VSCODE_CLIS+=(codium)

  if [ ${#VSCODE_CLIS[@]} -eq 0 ]; then
    printf "  - Skipping install: neither 'code' nor 'codium' on PATH. Built: tooling/vscode/%s\n" "$VSIX_FILE"
    popd > /dev/null
    return 0
  fi

  for cli in "${VSCODE_CLIS[@]}"; do
    printf "  - Installing via '%s'... " "$cli"
    if "$cli" --install-extension "$VSIX_FILE" --force > /dev/null 2>&1; then
      printf "Done\n"
    else
      printf "Failed!\n"
      echo "Failed to install the Abra extension via '$cli'. Please check editor permissions." >&2
      popd > /dev/null
      return 1
    fi
  done

  popd > /dev/null
}

install_abra_intellij_plugin() {
  printf "Installing Abra IntelliJ plugin...\n"

  # Find JDK 21 — required by the IntelliJ Platform Gradle Plugin
  if [ -d "/opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home" ]; then
    INTELLIJ_JAVA_HOME="/opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home"
  elif /usr/libexec/java_home -v 21 &> /dev/null; then
    INTELLIJ_JAVA_HOME=$(/usr/libexec/java_home -v 21)
  else
    echo "JDK 21 not found. Install it with: brew install openjdk@21" >&2
    return 1
  fi

  pushd tooling/intellij > /dev/null

  printf "  - Building plugin (JDK 21)... "
  if JAVA_HOME="$INTELLIJ_JAVA_HOME" ./gradlew buildPlugin --quiet > /dev/null 2>&1; then
    printf "Done\n"
  else
    printf "Failed!\n"
    echo "Failed to build the IntelliJ plugin." >&2
    popd > /dev/null
    return 1
  fi

  ZIP_FILE=$(ls -t build/distributions/*.zip 2>/dev/null | head -1)
  if [ -z "$ZIP_FILE" ]; then
    printf "Failed!\n"
    echo "No plugin zip found after build." >&2
    popd > /dev/null
    return 1
  fi

  popd > /dev/null

  # Install into JetBrains IDE plugins directories
  JETBRAINS_BASE="$HOME/Library/Application Support/JetBrains"
  INSTALLED=false
  if [ -d "$JETBRAINS_BASE" ]; then
    for dir in "$JETBRAINS_BASE"/RustRover* "$JETBRAINS_BASE"/IntelliJ* "$JETBRAINS_BASE"/CLion*; do
      if [ -d "$dir" ]; then
        PLUGINS_DIR="$dir/plugins"
        mkdir -p "$PLUGINS_DIR"
        # Remove old version if present
        rm -rf "$PLUGINS_DIR/abra-intellij-plugin"
        printf "  - Installing to %s... " "$(basename "$dir")"
        if unzip -qo "tooling/intellij/$ZIP_FILE" -d "$PLUGINS_DIR" > /dev/null 2>&1; then
          printf "Done\n"
          INSTALLED=true
        else
          printf "Failed!\n"
        fi
      fi
    done
  fi

  if [ "$INSTALLED" = false ]; then
    printf "  - No JetBrains IDE found. Plugin built at: tooling/intellij/%s\n" "$ZIP_FILE"
    echo "  - To install manually: Settings > Plugins > gear icon > Install Plugin from Disk..."
  else
    echo "  - Restart your IDE to load the updated plugin."
  fi
}

if [ $VIM = true ]; then
    install_vim_syntax_highlighting
fi

if [ $VSCODE = true ]; then
    install_abra_vscode_extension
fi

if [ $INTELLIJ = true ]; then
    install_abra_intellij_plugin
fi

printf "\nSetup complete! Abra is ready to use."
echo " To get started:"
echo "- Run \`abra --help\` to see available options."
echo "- Create a new Abra program and run it with \`abra <filename>.abra\`."

