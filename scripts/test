#!/bin/bash
set -eou pipefail

if [[ -n "${ABRA_REPOSITORY_ROOT-}" ]]; then
  export WD="$ABRA_REPOSITORY_ROOT"
else
  export WD="$PWD"
fi

cargo clippy

cargo test "$@"

# Run pure-Abra module tests
cargo build --quiet --package abra_module_core
echo ""
echo "running module tests"
FS_TESTS="read_write exists_copy_rename_remove directories path_manipulation environment glob_and_walk metadata symlinks permissions error_handling"
for test in $FS_TESTS; do
  printf "  fs::%-30s " "$test"
  if cargo run --quiet --package abra_cli --bin abra -- --standard-modules modules module_tests/fs.abra "$test" 2>&1; then
    echo "ok"
  else
    echo "FAILED"
    exit 1
  fi
done

pushd $WD/abra_core > /dev/null
cargo check --lib --target wasm32-unknown-unknown
popd > /dev/null

cargo deny check

mdbook build book

GREEN='\033[0;32m'
NC='\033[0m' # No Color
printf "${GREEN}PASSED${NC}\n"

