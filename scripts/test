#!/bin/bash
set -eou pipefail

if [[ -n "${ABRA_REPOSITORY_ROOT-}" ]]; then
  export WD="$ABRA_REPOSITORY_ROOT"
else
  export WD="$PWD"
fi

print_passed_message() {
  printf '\033[0;32mPASSED\033[0m\n'
}

run_module_tests() {
  cargo build --quiet --package abra_module_core
  echo ""
  echo "running module tests"
  for f in module_tests/*.abra; do
    [ "$(basename "$f")" = "test_runner.abra" ] && continue
    ./scripts/run "$f"
  done
}

if [[ "${1-}" == "--modules" ]]; then
  run_module_tests
  print_passed_message
  exit 0
fi

cargo fmt
cargo clippy

cargo test "$@"

# Run pure-Abra module tests
run_module_tests

pushd $WD/abra_core > /dev/null
cargo check --lib --target wasm32-unknown-unknown
popd > /dev/null

cargo deny check

mdbook build book

print_passed_message

