use core/json
use core/strings
use core/map
use test_runner

let t = TestRunner.new("json")
t.run("parse_null", test_parse_null())
t.run("parse_bool", test_parse_bool())
t.run("parse_number", test_parse_number())
t.run("parse_string", test_parse_string())
t.run("parse_array", test_parse_array())
t.run("parse_object", test_parse_object())
t.run("parse_nested", test_parse_nested())
t.run("parse_whitespace", test_parse_whitespace())
t.run("parse_escapes", test_parse_escapes())
t.run("parse_errors", test_parse_errors())
t.run("stringify_primitives", test_stringify_primitives())
t.run("stringify_array", test_stringify_array())
t.run("stringify_object", test_stringify_object())
t.run("stringify_pretty", test_stringify_pretty())
t.run("roundtrip", test_roundtrip())
t.run("accessors", test_accessors())
t.run("modify_object", test_modify_object())
t.run("modify_array", test_modify_array())
t.run("modify_nested", test_modify_nested())
t.run("constructors", test_constructors())
t.run("unicode_escapes", test_unicode_escapes())
t.finish()

fn test_parse_null() -> result<void, string> {
    let v = parse("null")?
    check(v.is_null(), "null should be null")?
    .ok(nil)
}

fn test_parse_bool() -> result<void, string> {
    let t = parse("true")?
    check(t.as_bool()! == true, "true")?
    let f = parse("false")?
    check(f.as_bool()! == false, "false")?
    .ok(nil)
}

fn test_parse_number() -> result<void, string> {
    let n = parse("42")?
    check(n.as_number()! == 42.0, "integer")?
    let f = parse("3.14")?
    check(f.as_number()! == 3.14, "float")?
    let neg = parse("-7")?
    check(neg.as_number()! == -7.0, "negative")?
    let exp = parse("1e3")?
    check(exp.as_number()! == 1000.0, "exponent")?
    let zero = parse("0")?
    check(zero.as_number()! == 0.0, "zero")?
    .ok(nil)
}

fn test_parse_string() -> result<void, string> {
    let s = parse("\"hello\"")?
    check(s.as_string()! == "hello", "basic string")?
    let empty = parse("\"\"")?
    check(empty.as_string()! == "", "empty string")?
    .ok(nil)
}

fn test_parse_array() -> result<void, string> {
    let arr = parse("[1, 2, 3]")?
    let items = arr.as_array()!
    check(items.len() == 3, "array length")?
    check(items[0].as_number()! == 1.0, "first element")?
    check(items[2].as_number()! == 3.0, "third element")?
    let empty = parse("[]")?
    check(empty.as_array()!.len() == 0, "empty array")?
    .ok(nil)
}

fn test_parse_object() -> result<void, string> {
    let obj = parse("{\"a\": 1, \"b\": 2}")?
    check(obj["a"].as_number()! == 1.0, "key a")?
    check(obj["b"].as_number()! == 2.0, "key b")?
    let empty = parse("{}")?
    check(empty.as_object()!.len() == 0, "empty object")?
    .ok(nil)
}

fn test_parse_nested() -> result<void, string> {
    let v = parse("{\"items\": [1, {\"nested\": true}], \"ok\": null}")?
    let items = v["items"].as_array()!
    check(items.len() == 2, "nested array length")?
    check(items[0].as_number()! == 1.0, "nested array first")?
    check(items[1]["nested"].as_bool()! == true, "deeply nested bool")?
    check(v["ok"].is_null(), "null value in object")?
    .ok(nil)
}

fn test_parse_whitespace() -> result<void, string> {
    let v = parse("  \n  { \"key\" :  \"value\"  }  \n")?
    check(v["key"].as_string()! == "value", "whitespace handling")?
    .ok(nil)
}

fn test_parse_escapes() -> result<void, string> {
    let v = parse("\"hello\\nworld\"")?
    check(v.as_string()! == "hello\nworld", "newline escape")?
    let v2 = parse("\"tab\\there\"")?
    check(v2.as_string()! == "tab\there", "tab escape")?
    let v3 = parse("\"quote\\\"here\"")?
    check(v3.as_string()! == "quote\"here", "quote escape")?
    let v4 = parse("\"back\\\\slash\"")?
    check(v4.as_string()! == "back\\slash", "backslash escape")?
    .ok(nil)
}

fn test_parse_errors() -> result<void, string> {
    check(parse("").is_err(), "empty input")?
    check(parse("{").is_err(), "unclosed object")?
    check(parse("[1,]").is_err(), "trailing comma")?
    check(parse("tru").is_err(), "truncated keyword")?
    check(parse("\"unclosed").is_err(), "unclosed string")?
    check(parse("42 extra").is_err(), "trailing chars")?
    .ok(nil)
}

fn test_stringify_primitives() -> result<void, string> {
    check(stringify(.Null) == "null", "null")?
    check(stringify(.Bool(true)) == "true", "true")?
    check(stringify(.Bool(false)) == "false", "false")?
    check(stringify(.Number(42.0)) == "42", "integer number")?
    check(stringify(.Number(3.14)) == "3.14", "float number")?
    check(stringify(.Str("hello")) == "\"hello\"", "string")?
    check(stringify(.Str("")) == "\"\"", "empty string")?
    .ok(nil)
}

fn test_stringify_array() -> result<void, string> {
    let arr: array<JsonValue> = []
    arr.push(.Number(1.0))
    arr.push(.Bool(true))
    arr.push(.Str("x"))
    let s = stringify(.Array(arr))
    check(s == "[1,true,\"x\"]", "mixed array: got " .. s)?
    let empty: array<JsonValue> = []
    check(stringify(.Array(empty)) == "[]", "empty array")?
    .ok(nil)
}

fn test_stringify_object() -> result<void, string> {
    let m: map<string, JsonValue> = map.new()
    check(stringify(.Object(m)) == "{}", "empty object")?
    m.insert("key", .Str("val"))
    let s = stringify(.Object(m))
    check(s == "{\"key\":\"val\"}", "single-key object: got " .. s)?
    .ok(nil)
}

fn test_stringify_pretty() -> result<void, string> {
    let arr: array<JsonValue> = []
    arr.push(.Number(1.0))
    arr.push(.Number(2.0))
    let s = stringify_pretty(.Array(arr))
    check(s.contains("\n"), "pretty has newlines")?
    check(s.contains("  "), "pretty has indentation")?
    .ok(nil)
}

fn test_roundtrip() -> result<void, string> {
    let input = "{\"name\":\"test\",\"values\":[1,2,3],\"active\":true,\"data\":null}"
    let parsed = parse(input)?
    let output = stringify(parsed)
    let reparsed = parse(output)?
    // verify key values survived roundtrip
    check(reparsed["name"].as_string()! == "test", "roundtrip name")?
    check(reparsed["active"].as_bool()! == true, "roundtrip bool")?
    check(reparsed["data"].is_null(), "roundtrip null")?
    let vals = reparsed["values"].as_array()!
    check(vals.len() == 3, "roundtrip array length")?
    check(vals[0].as_number()! == 1.0, "roundtrip array val")?
    .ok(nil)
}

fn test_accessors() -> result<void, string> {
    let v = parse("{\"a\": [10, 20]}")?
    check(v["a"].at(0).as_number()! == 10.0, "chained index/at")?
    check(v["a"].at(1).as_number()! == 20.0, "chained index/at second")?
    check(v.try_get("missing").is_none(), "try_get missing")?
    check(v.try_get("a").is_some(), "try_get present")?
    .ok(nil)
}

fn test_modify_object() -> result<void, string> {
    let v = parse("{\"a\": 1}")?
    v["b"] = .Number(2.0)
    check(v["b"].as_number()! == 2.0, "index_set new key")?
    v["a"] = .Number(99.0)
    check(v["a"].as_number()! == 99.0, "index_set updates existing")?
    check(v.remove("a"), "remove returns true for present key")?
    check(v.try_get("a").is_none(), "remove deletes key")?
    check(not v.remove("missing"), "remove returns false for missing key")?
    .ok(nil)
}

fn test_modify_array() -> result<void, string> {
    let v = parse("[1, 2, 3]")?
    v.push(.Number(4.0))
    check(v.as_array()!.len() == 4, "push appends")?
    check(v.at(3).as_number()! == 4.0, "push value")?
    v.set_at(0, .Number(99.0))
    check(v.at(0).as_number()! == 99.0, "set_at updates")?
    v.remove_at(1)
    check(v.as_array()!.len() == 3, "remove_at shrinks")?
    check(v.at(0).as_number()! == 99.0, "remove_at preserves head")?
    check(v.at(1).as_number()! == 3.0, "remove_at preserves middle order")?
    check(v.at(2).as_number()! == 4.0, "remove_at preserves tail")?
    .ok(nil)
}

fn test_unicode_escapes() -> result<void, string> {
    // ASCII
    let a = parse("\"\\u0041\"")?
    check(a.as_string()! == "A", "ascii unicode escape")?
    // 2-byte UTF-8 (é = U+00E9)
    let acute = parse("\"caf\\u00e9\"")?
    check(acute.as_string()! == "café", "2-byte utf8 escape")?
    // 3-byte UTF-8 (中 = U+4E2D)
    let zhong = parse("\"\\u4e2d\"")?
    check(zhong.as_string()! == "中", "3-byte utf8 escape")?
    // Surrogate pair (😀 = U+1F600 → 😀)
    let emoji = parse("\"\\uD83D\\uDE00\"")?
    check(emoji.as_string()! == "😀", "surrogate pair")?
    // Uppercase hex
    let upper = parse("\"\\u0041\"")?
    check(upper.as_string()! == "A", "uppercase hex digits")?
    // Errors
    check(parse("\"\\u00\"").is_err(), "truncated escape")?
    check(parse("\"\\uD83D\"").is_err(), "lone high surrogate")?
    check(parse("\"\\uDC00\"").is_err(), "lone low surrogate")?
    check(parse("\"\\uD83Dx\"").is_err(), "high surrogate not followed by \\u")?
    .ok(nil)
}

fn test_constructors() -> result<void, string> {
    let obj = JsonValue.object()
    check(obj.as_object()!.len() == 0, "object() is empty")?
    obj["name"] = .Str("abra")
    obj["count"] = .Number(3.0)
    check(obj["name"].as_string()! == "abra", "index_set on constructed object")?
    check(stringify(obj).contains("\"name\":\"abra\""), "stringify constructed object")?

    let arr = JsonValue.array()
    check(arr.as_array()!.len() == 0, "array() is empty")?
    arr.push(.Number(1.0))
    arr.push(.Bool(true))
    check(arr.as_array()!.len() == 2, "push on constructed array")?
    check(stringify(arr) == "[1,true]", "stringify constructed array")?
    .ok(nil)
}

fn test_modify_nested() -> result<void, string> {
    let v = parse("{\"items\": [1, 2], \"meta\": {\"count\": 0}}")?
    // mutate nested object via chained index
    v["meta"]["count"] = .Number(2.0)
    check(v["meta"]["count"].as_number()! == 2.0, "nested object index_set")?
    // mutate nested array
    v["items"].push(.Number(3.0))
    check(v["items"].as_array()!.len() == 3, "nested array push")?
    check(v["items"].at(2).as_number()! == 3.0, "nested array push value")?
    // verify changes survive stringify
    let s = stringify(v)
    let reparsed = parse(s)?
    check(reparsed["meta"]["count"].as_number()! == 2.0, "roundtrip after mutation")?
    check(reparsed["items"].as_array()!.len() == 3, "roundtrip array length")?
    .ok(nil)
}
