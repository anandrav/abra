use core/env
use test_runner

let t = TestRunner.new("env")
t.run("set_and_get", test_set_and_get())
t.run("overwrite", test_overwrite())
t.run("get_missing", test_get_missing())
t.finish()

fn test_set_and_get() -> result<void, string> {
    set_var("ABRA_TEST_VAR_1", "hello")
    check(get_var("ABRA_TEST_VAR_1") == "hello", "should read back set value")?
    .ok(nil)
}

fn test_overwrite() -> result<void, string> {
    set_var("ABRA_TEST_VAR_2", "first")
    set_var("ABRA_TEST_VAR_2", "second")
    check(get_var("ABRA_TEST_VAR_2") == "second", "should read back overwritten value")?
    .ok(nil)
}

fn test_get_missing() -> result<void, string> {
    check(get_var("ABRA_TEST_NONEXISTENT_XYZ") == "", "missing var should return empty string")?
    .ok(nil)
}
