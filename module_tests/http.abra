t.finish()
*/

fn test_get_basic() -> result<void, string> {
    let resp = get("https://httpbin.org/get").map_err(str_err)?
    check(resp.ok(), "status should be 2xx, got: " .. resp.status)?
    check(resp.body.len() > 0, "body should not be empty")?
    .ok(nil)
}

fn test_get_headers() -> result<void, string> {
    let resp = get("https://httpbin.org/get").map_err(str_err)?
    let ct = resp.header("content-type")
    check(ct.is_some(), "should have content-type header")?
    check(ct!.contains("json"), "content-type should contain json")?
    .ok(nil)
}

fn test_get_404() -> result<void, string> {
    let resp = get("https://httpbin.org/status/404").map_err(str_err)?
    check(resp.status == 404, "status should be 404, got: " .. resp.status)?
    check(not resp.ok(), "ok() should be false for 404")?
    .ok(nil)
}

fn test_post_basic() -> result<void, string> {
    let resp = post("https://httpbin.org/post", "hello world").map_err(str_err)?
    check(resp.ok(), "status should be 2xx, got: " .. resp.status)?
    check(resp.body.contains("hello world"), "response should echo the body")?
    .ok(nil)
}

fn test_request_builder() -> result<void, string> {
    let resp = request("GET", "https://httpbin.org/headers") \
        .header("X-Custom", "test-value") \
        .send() \
        .map_err(str_err)?
    check(resp.ok(), "status should be 2xx")?
    check(resp.body.contains("test-value"), "response should include custom header value")?
    .ok(nil)
}

fn test_response_json() -> result<void, string> {
    let resp = get("https://httpbin.org/get").map_err(str_err)?
    let json = resp.json()?
    let url = json.get("url").as_string()
    check(url.is_some(), "json should have url field")?
    check(url!.contains("httpbin.org"), "url should contain httpbin.org")?
    .ok(nil)
}

fn test_post_json() -> result<void, string> {
    let m: map<string, JsonValue> = map.new()
    m.insert("name", .Str("abra"))
    m.insert("version", .Number(1.0))
    let resp = post_json("https://httpbin.org/post", .Object(m)).map_err(str_err)?
    check(resp.ok(), "status should be 2xx")?
    let json = resp.json()?
    let ct = json.get("headers").get("Content-Type").as_string()!
    check(ct.contains("application/json"), "content-type should be json, got: " .. ct)?
    .ok(nil)
}

fn test_request_json_body() -> result<void, string> {
    let m: map<string, JsonValue> = map.new()
    m.insert("key", .Str("value"))
    let resp = request("PUT", "https://httpbin.org/put") \
        .json_body(.Object(m)) \
        .send() \
        .map_err(str_err)?
    check(resp.ok(), "status should be 2xx")?
    let json = resp.json()?
    let ct = json.get("headers").get("Content-Type").as_string()!
    check(ct.contains("application/json"), "content-type should be json")?
    .ok(nil)
}

fn test_connection_error() -> result<void, string> {
    let r = get("http://localhost:1")
    check(r.is_err(), "should fail to connect")?
    .ok(nil)
}

