use core/fs
use test_runner

fn str_err(e: FsError) -> string = e.str()

let t = TestRunner.new("fs")
t.run("read_write", test_read_write())
t.run("exists_copy_rename_remove", test_exists_copy_rename_remove())
t.run("directories", test_directories())
t.run("path_manipulation", test_path_manipulation())
t.run("environment", test_environment())
t.run("glob_and_walk", test_glob_and_walk())
t.run("metadata", test_metadata())
t.run("symlinks", test_symlinks())
t.run("permissions", test_permissions())
t.run("error_handling", test_error_handling())
t.finish()

fn test_read_write() -> result<void, string> {
    write("_test_rw.txt", "hello world").map_err(str_err)?
    let contents = read("_test_rw.txt").map_err(str_err)?
    check(contents == "hello world", "read after write")?

    append("_test_rw.txt", "line2").map_err(str_err)?
    let contents2 = read("_test_rw.txt").map_err(str_err)?
    check(contents2 == "hello worldline2", "read after append")?

    remove("_test_rw.txt").map_err(str_err)?
    .ok(nil)
}

fn test_exists_copy_rename_remove() -> result<void, string> {
    write("_test_ecr.txt", "data").map_err(str_err)?
    check(exists("_test_ecr.txt").map_err(str_err)?, "file exists after write")?
    check(not exists("_test_ecr_nope.txt").map_err(str_err)?, "nonexistent file does not exist")?

    copy("_test_ecr.txt", "_test_ecr_copy.txt").map_err(str_err)?
    check(exists("_test_ecr_copy.txt").map_err(str_err)?, "copy exists")?
    rename("_test_ecr_copy.txt", "_test_ecr_renamed.txt").map_err(str_err)?
    check(not exists("_test_ecr_copy.txt").map_err(str_err)?, "old name gone after rename")?
    check(exists("_test_ecr_renamed.txt").map_err(str_err)?, "new name exists after rename")?

    remove("_test_ecr.txt").map_err(str_err)?
    remove("_test_ecr_renamed.txt").map_err(str_err)?
    check(not exists("_test_ecr.txt").map_err(str_err)?, "removed file gone")?
    check(not exists("_test_ecr_renamed.txt").map_err(str_err)?, "removed renamed file gone")?

    .ok(nil)
}

fn test_directories() -> result<void, string> {
    mkdir("_test_dirs").map_err(str_err)?
    check(is_dir("_test_dirs"), "mkdir creates directory")?
    check(not is_file("_test_dirs"), "directory is not a file")?

    write("_test_dirs/a.txt", "a").map_err(str_err)?
    write("_test_dirs/b.txt", "b").map_err(str_err)?
    let files = list_dir("_test_dirs").map_err(str_err)?
    check(files.len() == 2, "list_dir count")?

    rmdir_all("_test_dirs").map_err(str_err)?
    check(not exists("_test_dirs").map_err(str_err)?, "rmdir_all removes directory")?

    mkdir_all("_test_dirs/nested/deep").map_err(str_err)?
    check(is_dir("_test_dirs/nested/deep"), "mkdir_all creates nested dirs")?
    rmdir_all("_test_dirs").map_err(str_err)?

    .ok(nil)
}

fn test_path_manipulation() -> result<void, string> {
    check(join("foo", "bar.txt") == "foo/bar.txt", "join")?
    check(parent("/a/b/c.txt").unwrap() == "/a/b", "parent")?
    check(filename("/a/b/c.txt").unwrap() == "c.txt", "filename")?
    check(extension("/a/b/c.txt").unwrap() == "txt", "extension")?
    check(stem("/a/b/c.txt").unwrap() == "c", "stem")?
    check(extension("noext").is_none(), "extension of file with no extension")?
    check(parent("lonely").unwrap() == "", "parent of bare filename")?
    .ok(nil)
}

fn test_environment() -> result<void, string> {
    let cwd = getcwd().map_err(str_err)?
    check(is_dir(cwd), "cwd is a directory")?
    check(is_dir(temp_dir()), "temp_dir is a directory")?

    let tmp = temp_file().map_err(str_err)?
    check(is_file(tmp), "temp_file creates a file")?
    remove(tmp).map_err(str_err)?

    .ok(nil)
}

fn test_glob_and_walk() -> result<void, string> {
    mkdir_all("_test_gw/sub").map_err(str_err)?
    write("_test_gw/one.txt", "1").map_err(str_err)?
    write("_test_gw/two.txt", "2").map_err(str_err)?
    write("_test_gw/three.log", "3").map_err(str_err)?
    write("_test_gw/sub/four.txt", "4").map_err(str_err)?

    let txt_files = glob("_test_gw/*.txt").map_err(str_err)?
    check(txt_files.len() == 2, "glob *.txt count")?
    let all_txt = glob("_test_gw/**/*.txt").map_err(str_err)?
    check(all_txt.len() == 3, "glob **/*.txt count")?
    let log_files = glob("_test_gw/*.log").map_err(str_err)?
    check(log_files.len() == 1, "glob *.log count")?

    let all_files = walk_dir("_test_gw").map_err(str_err)?
    check(all_files.len() == 4, "walk_dir count")?

    rmdir_all("_test_gw").map_err(str_err)?
    .ok(nil)
}

fn test_metadata() -> result<void, string> {
    write("_test_meta.txt", "twelve chars").map_err(str_err)?

    check(is_file("_test_meta.txt"), "is_file")?
    check(not is_dir("_test_meta.txt"), "not is_dir")?
    check(file_size("_test_meta.txt").map_err(str_err)? == 12, "file_size")?
    let mtime = modified_time("_test_meta.txt").map_err(str_err)?
    check(mtime > 0.0, "modified_time > 0")?

    remove("_test_meta.txt").map_err(str_err)?
    .ok(nil)
}

fn test_symlinks() -> result<void, string> {
    write("_test_sym.txt", "linked content").map_err(str_err)?

    symlink("_test_sym.txt", "_test_sym_link").map_err(str_err)?
    check(is_symlink("_test_sym_link"), "link is symlink")?
    check(not is_symlink("_test_sym.txt"), "original is not symlink")?
    let target = read_link("_test_sym_link").map_err(str_err)?
    check(target == "_test_sym.txt", "read_link target")?
    let link_contents = read("_test_sym_link").map_err(str_err)?
    check(link_contents == "linked content", "read through symlink")?

    remove("_test_sym_link").map_err(str_err)?
    remove("_test_sym.txt").map_err(str_err)?
    .ok(nil)
}

fn test_permissions() -> result<void, string> {
    write("_test_perm.txt", "x").map_err(str_err)?

    check(not is_executable("_test_perm.txt").map_err(str_err)?, "not executable initially")?
    set_executable("_test_perm.txt", true).map_err(str_err)?
    check(is_executable("_test_perm.txt").map_err(str_err)?, "executable after set")?
    set_executable("_test_perm.txt", false).map_err(str_err)?
    check(not is_executable("_test_perm.txt").map_err(str_err)?, "not executable after unset")?

    remove("_test_perm.txt").map_err(str_err)?
    .ok(nil)
}

fn test_error_handling() -> result<void, string> {
    let r1: result<string, FsError> = read("_test_err_nonexistent.txt")
    match r1 {
        .ok(_) -> return .err("expected error from read")
        .err(.NotFound(_)) -> nil
        .err(_) -> return .err("wrong error kind from read")
    }

    let r2: result<void, FsError> = remove("_test_err_nonexistent.txt")
    match r2 {
        .ok(_) -> return .err("expected error from remove")
        .err(.NotFound(_)) -> nil
        .err(_) -> return .err("wrong error kind from remove")
    }

    let r3: result<void, FsError> = mkdir("_test_err_dir/nested/deep")
    match r3 {
        .ok(_) -> return .err("expected error from mkdir")
        .err(.NotFound(_)) -> nil
        .err(_) -> return .err("wrong error kind from mkdir")
    }

    let r4: result<string, FsError> = read("_test_err_no_such_file.txt")
    match r4 {
        .ok(_) -> return .err("expected error from read")
        .err(.NotFound(_)) -> nil
        .err(_) -> return .err("wrong error kind from read")
    }

    .ok(nil)
}
