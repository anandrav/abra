use core/fs

fn check(cond: bool, msg: string) -> result<void, string> {
    if cond { result.ok(nil) } else { result.err(msg) }
}

type TestRunner = { failed: int }

extend TestRunner {
    fn new() -> TestRunner { TestRunner(0) }

    fn run(self, name: string, r: result<void, E ToString>) {
        print("  fs::" .. name .. " ... ")
        match r {
            result.ok(_) -> println("ok")
            result.err(e) -> { println("FAILED: " .. e); self.failed = self.failed + 1 }
        }
    }

    fn finish(self) {
        if self.failed > 0 {
            panic(self.failed .. " test(s) failed")
        }
    }
}

let t = TestRunner.new()
t.run("read_write", test_read_write())
t.run("exists_copy_rename_remove", test_exists_copy_rename_remove())
t.run("directories", test_directories())
t.run("path_manipulation", test_path_manipulation())
t.run("environment", test_environment())
t.run("glob_and_walk", test_glob_and_walk())
t.run("metadata", test_metadata())
t.run("symlinks", test_symlinks())
t.run("permissions", test_permissions())
t.run("error_handling", test_error_handling())
t.finish()

fn test_read_write() -> result<void, FsError> {
    write("_test_rw.txt", "hello world")?
    let contents = read("_test_rw.txt")?
    assert(contents == "hello world", "read after write")

    append("_test_rw.txt", "line2")?
    let contents2 = read("_test_rw.txt")?
    assert(contents2 == "hello worldline2", "read after append")

    remove("_test_rw.txt")?
    result.ok(nil)
}

fn test_exists_copy_rename_remove() -> result<void, FsError> {
    write("_test_ecr.txt", "data")?
    assert(exists("_test_ecr.txt")?, "file exists after write")
    assert(not exists("_test_ecr_nope.txt")?, "nonexistent file does not exist")

    copy("_test_ecr.txt", "_test_ecr_copy.txt")?
    assert(exists("_test_ecr_copy.txt")?, "copy exists")
    rename("_test_ecr_copy.txt", "_test_ecr_renamed.txt")?
    assert(not exists("_test_ecr_copy.txt")?, "old name gone after rename")
    assert(exists("_test_ecr_renamed.txt")?, "new name exists after rename")

    remove("_test_ecr.txt")?
    remove("_test_ecr_renamed.txt")?
    assert(not exists("_test_ecr.txt")?, "removed file gone")
    assert(not exists("_test_ecr_renamed.txt")?, "removed renamed file gone")

    result.ok(nil)
}

fn test_directories() -> result<void, FsError> {
    mkdir("_test_dirs")?
    assert(is_dir("_test_dirs"), "mkdir creates directory")
    assert(not is_file("_test_dirs"), "directory is not a file")

    write("_test_dirs/a.txt", "a")?
    write("_test_dirs/b.txt", "b")?
    let files = list_dir("_test_dirs")?
    assert(files.len() == 2, "list_dir count")

    rmdir_all("_test_dirs")?
    assert(not exists("_test_dirs")?, "rmdir_all removes directory")

    mkdir_all("_test_dirs/nested/deep")?
    assert(is_dir("_test_dirs/nested/deep"), "mkdir_all creates nested dirs")
    rmdir_all("_test_dirs")?

    result.ok(nil)
}

fn test_path_manipulation() -> result<void, string> {
    check(join("foo", "bar.txt") == "foo/bar.txt", "join")?
    check(parent("/a/b/c.txt").unwrap() == "/a/b", "parent")?
    check(filename("/a/b/c.txt").unwrap() == "c.txt", "filename")?
    check(extension("/a/b/c.txt").unwrap() == "txt", "extension")?
    check(stem("/a/b/c.txt").unwrap() == "c", "stem")?
    check(extension("noext").is_none(), "extension of file with no extension")?
    check(parent("lonely").unwrap() == "", "parent of bare filename")?
    result.ok(nil)
}

fn test_environment() -> result<void, FsError> {
    let cwd = getcwd()?
    assert(is_dir(cwd), "cwd is a directory")
    assert(is_dir(temp_dir()), "temp_dir is a directory")

    let tmp = temp_file()?
    assert(is_file(tmp), "temp_file creates a file")
    remove(tmp)?

    result.ok(nil)
}

fn test_glob_and_walk() -> result<void, FsError> {
    mkdir_all("_test_gw/sub")?
    write("_test_gw/one.txt", "1")?
    write("_test_gw/two.txt", "2")?
    write("_test_gw/three.log", "3")?
    write("_test_gw/sub/four.txt", "4")?

    let txt_files = glob("_test_gw/*.txt")?
    assert(txt_files.len() == 2, "glob *.txt count")
    let all_txt = glob("_test_gw/**/*.txt")?
    assert(all_txt.len() == 3, "glob **/*.txt count")
    let log_files = glob("_test_gw/*.log")?
    assert(log_files.len() == 1, "glob *.log count")

    let all_files = walk_dir("_test_gw")?
    assert(all_files.len() == 4, "walk_dir count")

    rmdir_all("_test_gw")?
    result.ok(nil)
}

fn test_metadata() -> result<void, FsError> {
    write("_test_meta.txt", "twelve chars")?

    assert(is_file("_test_meta.txt"), "is_file")
    assert(not is_dir("_test_meta.txt"), "not is_dir")
    assert(file_size("_test_meta.txt")? == 12, "file_size")
    let mtime = modified_time("_test_meta.txt")?
    assert(mtime > 0.0, "modified_time > 0")

    remove("_test_meta.txt")?
    result.ok(nil)
}

fn test_symlinks() -> result<void, FsError> {
    write("_test_sym.txt", "linked content")?

    symlink("_test_sym.txt", "_test_sym_link")?
    assert(is_symlink("_test_sym_link"), "link is symlink")
    assert(not is_symlink("_test_sym.txt"), "original is not symlink")
    let target = read_link("_test_sym_link")?
    assert(target == "_test_sym.txt", "read_link target")
    let link_contents = read("_test_sym_link")?
    assert(link_contents == "linked content", "read through symlink")

    remove("_test_sym_link")?
    remove("_test_sym.txt")?
    result.ok(nil)
}

fn test_permissions() -> result<void, FsError> {
    write("_test_perm.txt", "x")?

    assert(not is_executable("_test_perm.txt")?, "not executable initially")
    set_executable("_test_perm.txt", true)?
    assert(is_executable("_test_perm.txt")?, "executable after set")
    set_executable("_test_perm.txt", false)?
    assert(not is_executable("_test_perm.txt")?, "not executable after unset")

    remove("_test_perm.txt")?
    result.ok(nil)
}

fn test_error_handling() -> result<void, string> {
    let r1: result<string, FsError> = read("_test_err_nonexistent.txt")
    match r1 {
        result.ok(_) -> return result.err("expected error from read")
        result.err(FsError.NotFound(_)) -> nil
        result.err(_) -> return result.err("wrong error kind from read")
    }

    let r2: result<void, FsError> = remove("_test_err_nonexistent.txt")
    match r2 {
        result.ok(_) -> return result.err("expected error from remove")
        result.err(FsError.NotFound(_)) -> nil
        result.err(_) -> return result.err("wrong error kind from remove")
    }

    let r3: result<void, FsError> = mkdir("_test_err_dir/nested/deep")
    match r3 {
        result.ok(_) -> return result.err("expected error from mkdir")
        result.err(FsError.NotFound(_)) -> nil
        result.err(_) -> return result.err("wrong error kind from mkdir")
    }

    let r4: result<string, FsError> = read("_test_err_no_such_file.txt")
    match r4 {
        result.ok(_) -> return result.err("expected error from read")
        result.err(FsError.NotFound(_)) -> nil
        result.err(_) -> return result.err("wrong error kind from read")
    }

    result.ok(nil)
}
